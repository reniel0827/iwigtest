# ====== Required ======

# GoHighLevel Private Integration token (starts with "pit-")
# Settings → Private Integrations → Create
# REQUIRED SCOPES (enable ALL of these — you cannot add scopes later, must recreate):
#   - contacts.readonly
#   - contacts.write
#   - products.readonly
#   - products/prices.readonly   <-- IMPORTANT for product prices to load
GHL_PRIVATE_TOKEN=pit-08ab22f1-40da-4a8e-9fa0-f035f3f7808f

# Your GHL sub-account (location) ID
# Settings → Business Profile → top-right (or copy from URL)
GHL_LOCATION_ID=JSOXIBOOm0QbvX6P2BbN

# Your checkout form URL — paste a public form URL from GHL
# Sites → Forms → (your wholesale checkout form) → Embed → URL
GHL_CHECKOUT_FORM_URL=https://api.leadconnectorhq.com/widget/form/XXXXXXXXX

# Admin dashboard password (you choose this)
ADMIN_PASSWORD=iWigAdmin

# Random string for signing admin tokens (any 32+ random chars)
ADMIN_SECRET=replace-with-random-32-char-string

# ====== Optional: custom field IDs from GHL ======
# Create these in Settings → Custom Fields, then paste their IDs here.
CF_BUSINESS_TYPE=
CF_RESELLER_ID=
CF_NOTES=

# Optional: GHL user ID (for attaching notes)
GHL_USER_ID=
